# Copy this file to .env for local testing, or set this in your
# Vercel project settings under Settings -> Environment Variables.
# NEVER put these keys in appealist.html or any file the browser can see.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# From dashboard.lob.com -> Settings -> API Keys. Start with the TEST key
# (starts with "test_") while you're building — it doesn't actually mail
# anything or charge you, but returns realistic responses. Switch to the
# LIVE key (starts with "live_") only once you're ready to send real mail.
LOB_API_KEY=test_your_key_here

# --- Rate limiting (protects your Anthropic + Lob budget) ---
# Free account at upstash.com -> Create Database (Redis, free tier) ->
# copy these two values from the "REST API" section of that database.
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token-here

# --- CORS (locks the API to your own site only) ---
# Your real deployed site URL, no trailing slash. Use your .vercel.app URL
# until you have a custom domain, then update this to the custom domain.
ALLOWED_ORIGIN=https://appealist.vercel.app
